# ============================================================================
# Configuracion de Entorno de Ejemplo - Chatbot de WhatsApp (Kapso)
# ============================================================================
#
# Renombra este archivo a .env en tu servidor y configura las credenciales
# de tu cuenta de Kapso.ai para correr el webhook de ejemplo.
#

# Credenciales de API de Kapso
KAPSO_API_KEY=tu_kapso_api_key_aqui

# ID de la cuenta de WhatsApp Business asociada en Kapso
KAPSO_WABA_ID=tu_kapso_waba_id_aqui

# Puerto local del servidor (opcional)
PORT=3000
